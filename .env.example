# Felix Academy Environment Variables
# Version: 10.2 - Security Enhanced
# NEVER commit .env file to git! Add .env to .gitignore

# ===== REQUIRED =====

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Groq AI API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Database URL (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ===== ADMIN =====

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321
ADMIN_ID=your_telegram_user_id

# ===== OPTIONAL =====

# Mini App URL
MINIAPP_URL=https://your-project.vercel.app/miniapp/index.html

# Environment
NODE_ENV=production
VERCEL_ENV=production

# ===== RATE LIMITING =====

# AI Rate Limits
AI_DAILY_LIMIT=50
AI_HOURLY_LIMIT=10
AI_RATE_LIMIT_PER_DAY=50
MESSAGE_RATE_LIMIT_PER_MINUTE=20

# ===== VOICE ASSISTANT (Optional) =====

# Voice settings
VOICE_DEFAULT_LANGUAGE=ru
VOICE_DEFAULT_VOICE=Jarvis
VOICE_DEFAULT_SPEED=1.0

# ===== MONITORING (Optional) =====

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn_here

# ===== CACHING (Optional) =====

# Vercel KV (Redis) - Get from Vercel Dashboard
KV_URL=your_kv_url_here
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token_here
