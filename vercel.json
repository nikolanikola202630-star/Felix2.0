{
  "version": 2,
  "builds": [
    {
      "src": "api/_router.js",
      "use": "@vercel/node"
    },
    {
      "src": "miniapp/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/_router.js"
    },
    {
      "src": "/miniapp/(.*)",
      "dest": "/miniapp/$1",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/miniapp/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
