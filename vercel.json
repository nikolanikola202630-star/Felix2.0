{
  "version": 2,
  "builds": [
    {
      "src": "api/_router.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/_router.js"
    },
    {
      "src": "/miniapp/(.*)",
      "dest": "/miniapp/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/miniapp/elite.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
