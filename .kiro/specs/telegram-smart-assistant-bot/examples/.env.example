# Database
DATABASE_URL=postgresql://user:password@localhost:5432/telegram_bot

# Redis
REDIS_URL=redis://localhost:6379

# Groq API
GROQ_API_KEY=gsk_your_groq_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Encryption (для OAuth токенов)
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# S3 / Supabase Storage
S3_BUCKET=telegram-bot-files
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com  # или Supabase Storage endpoint
S3_REGION=us-east-1

# Sentry (опционально)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Vercel (автоматически устанавливаются Vercel)
# VERCEL_ENV=production
# VERCEL_REGION=iad1
# VERCEL_URL=your-app.vercel.app

# Frontend (для локальной разработки)
VITE_API_URL=http://localhost:8000
VITE_TELEGRAM_BOT_USERNAME=your_bot
