{
  "name": "felix-bot",
  "version": "7.1.0",
  "description": "Felix Bot - AI Assistant with full database integration",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sentry/node": "^7.120.4",
    "@supabase/supabase-js": "^2.39.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^1.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "groq-sdk": "^0.3.0",
    "joi": "^17.11.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "node-pg-migrate": "^6.2.2",
    "supertest": "^6.3.4",
    "vitest": "^1.6.1"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:supabase": "node scripts/test-supabase.js",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:status": "node-pg-migrate status",
    "dev": "vercel dev",
    "build": "echo 'No build step required'",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "deploy:auto": "node scripts/auto-deploy.js",
    "autonomy:cycle": "node scripts/autonomy-runner.js cycle",
    "autonomy:analyze": "node scripts/autonomy-runner.js analyze",
    "autonomy:optimize": "node scripts/autonomy-runner.js optimize",
    "autonomy:start": "node scripts/autonomy-runner.js start",
    "vercel:setup": "node scripts/setup-vercel.js",
    "vercel:link": "vercel link",
    "vercel:env": "vercel env ls",
    "vercel:logs": "vercel logs",
    "vercel:inspect": "vercel inspect",
    "start:ml": "node -e \"require('./lib/automation/self-learning').start()\"",
    "health": "curl https://felix2-0.vercel.app/api/webhook"
  }
}
